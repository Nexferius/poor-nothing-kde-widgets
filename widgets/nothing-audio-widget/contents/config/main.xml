        <entry name="labelLineout" type="String">
            <default>SPEAKERS</default>
        </entry>
        <entry name="labelHeadphones" type="String">
            <default>HEADPHONES</default>
        </entry>
        <entry name="updateInterval" type="Int">
            <default>3000</default>
        </entry>
    </group>
</kcfg>
